# Meta WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=           # Permanent access token from Meta Business > System Users > Generate Token
WHATSAPP_PHONE_NUMBER_ID=        # Phone Number ID from Meta App > WhatsApp > API Setup
WHATSAPP_VERIFY_TOKEN=           # Any string you choose (e.g. "myverifytoken123") - used to verify webhook

# AI Model (OpenRouter or OpenAI-compatible)
OPENROUTER_API_KEY=              # API key from openrouter.ai
AI_MODEL=                        # Model slug, e.g. z-ai/glm-4.5-air:free or anthropic/claude-3.5-sonnet
# OPENAI_API_KEY=                # Optional: only if using OpenAI Whisper for transcription
# AI_VISION_MODEL=               # Optional: separate model for image understanding

# Supabase
NEXT_PUBLIC_SUPABASE_URL=        # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # Supabase anon/public key (frontend)
SUPABASE_SERVICE_ROLE_KEY=       # Supabase service role key (backend only - keep secret)
